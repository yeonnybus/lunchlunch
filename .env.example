NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Manual crawl API auth
MANUAL_TRIGGER_TOKEN=change-this-to-a-long-random-secret

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Weather baseline location (default: Seoul)
WEATHER_LAT=37.5665
WEATHER_LNG=126.9780

# Region and workplace policy
ALLOWED_REGION_KEYWORD=여의도동
WORKPLACE_ADDRESS=서울 영등포구 여의대로 66
WORKPLACE_LAT=37.525167
WORKPLACE_LNG=126.927028

# Auth and API safeguards
RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=20

# Geocoding for distance buckets
GEOCODING_ENABLED=true
GEOCODING_TIMEOUT_MS=8000
GEOCODING_MAX_PER_REQUEST=12

# Naver crawler behavior
NAVER_CRAWLER_MAX_SCROLLS=35
NAVER_CRAWLER_HEADLESS=true
NAVER_CRAWLER_TIMEOUT_MS=20000

# Optional for CLI scripts
CRAWL_REGION=서울 영등포구 여의도동
