{
  "name": "lunchlunch",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "crawl:naver": "tsx scripts/run-crawl.ts",
    "crawl:matrix": "tsx scripts/run-crawl-matrix.ts",
    "crawl:yeouido-full": "tsx scripts/run-crawl-yeouido-full.ts",
    "backfill:signals": "tsx scripts/backfill-restaurant-signals.ts",
    "audit:recommendation": "tsx scripts/audit-recommendation-integrity.ts",
    "audit:recommendation:full": "tsx scripts/audit-recommendation-integrity.ts --suite full --out docs/reports/recommendation-regression-latest.json",
    "ops:daily": "tsx scripts/ops-daily-healthcheck.ts",
    "recommend:dry": "tsx scripts/run-recommendation-dry.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "lucide-react": "^1.8.0",
    "next": "^14.2.33",
    "openai": "^6.34.0",
    "playwright": "^1.59.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^14.2.33",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
